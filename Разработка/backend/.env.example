# =============================================================
# GymFuel AI Backend — environment variables (example)
# -------------------------------------------------------------
# Скопировать в .env и заполнить реальными значениями.
# НЕ коммитить .env в git.
# =============================================================

# --- Application ---------------------------------------------
ENV=development                   # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
PORT=8000
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,https://gymfuel.ai

# --- Supabase ------------------------------------------------
# https://app.supabase.com/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=             # service_role — только на бэке, никогда на фронте

# --- AI-сервисы ---------------------------------------------
# Google Gemini (распознавание фото)
GEMINI_API_KEY=

# Anthropic Claude (AI-диетолог, v1.0 — не MVP)
ANTHROPIC_API_KEY=

# --- JWT -----------------------------------------------------
# Если используем свой JWT поверх Supabase (обычно — нет)
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=604800

# --- Redis (кеш) ---------------------------------------------
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_RECOGNITION=86400       # 24 часа на кеш распознаваний
CACHE_TTL_DAILY_STATS=300         # 5 мин на дневные агрегаты

# --- Внешние API питания -------------------------------------
# USDA FoodData Central: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# Open Food Facts — публичный API, ключ не нужен
OFF_USER_AGENT=GymFuelAI/0.1 (contact@gymfuel.ai)

# --- Rate Limiting ------------------------------------------
RATE_LIMIT_FREE_PER_MINUTE=60
RATE_LIMIT_PRO_PER_MINUTE=300

# --- Ngrok (только локальный dev, profile=tunnel) ----------
NGROK_AUTHTOKEN=
